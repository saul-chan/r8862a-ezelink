}

// 初始化串口
int init_serial() {
    struct termios options;
    
    int fd = open(config.serial_device, O_RDWR | O_NOCTTY | O_NDELAY);
    if (fd == -1) {
        perror("Unable to open serial port");
        return -1;
    }
    
    // 确保串口不被其他进程占用
    if (fcntl(fd, F_SETFL, 0) == -1) {
        perror("fcntl F_SETFL");
        close(fd);
        return -1;
    }
    
    // 获取当前串口设置
    if (tcgetattr(fd, &options) == -1) {
        perror("tcgetattr");
        close(fd);
        return -1;
    }
    
    // 设置输入输出波特率
    cfsetispeed(&options, config.baudrate);
    cfsetospeed(&options, config.baudrate);
    
    // 设置数据位
    options.c_cflag &= ~CSIZE;
    switch (config.databits) {
        case 5:
            options.c_cflag |= CS5;
            break;
        case 6:
            options.c_cflag |= CS6;
            break;
        case 7:
            options.c_cflag |= CS7;
            break;
        case 8:
        default:
            options.c_cflag |= CS8;
            break;
    }
    
    // 设置停止位
    if (config.stopbits == 2) {
        options.c_cflag |= CSTOPB;
    } else {
        options.c_cflag &= ~CSTOPB;
    }
    
    // 设置校验位
    switch (config.parity) {
        case 'O':  // 奇校验
            options.c_cflag |= PARENB;
            options.c_cflag |= PARODD;
            break;
        case 'E':  // 偶校验
            options.c_cflag |= PARENB;
            options.c_cflag &= ~PARODD;
            break;
        case 'N':  // 无校验
        default:
            options.c_cflag &= ~PARENB;
            break;
    }
    
    // 启用接收器
    options.c_cflag |= (CLOCAL | CREAD);
    
    // 禁用硬件流控
    options.c_cflag &= ~CRTSCTS;
    
    // 原始输入模式
    options.c_lflag &= ~(ICANON | ECHO | ECHOE | ISIG);
    
    // 原始输出模式
    options.c_oflag &= ~OPOST;
    
    // 设置超时
    options.c_cc[VMIN] = 0;
    options.c_cc[VTIME] = (config.timeout_ms + 99) / 100; // 转换为十分之一秒
    
    // 应用设置
    if (tcsetattr(fd, TCSANOW, &options) == -1) {
        perror("tcsetattr");
        close(fd);
        return -1;
    }
    
    return fd;
}

// MQTT断开连接回调
void on_disconnect(struct mosquitto *mosq, void *obj, int rc) {
    printf("Disconnected from MQTT broker: %s\n", mosquitto_strerror(rc));
    mqtt_connected = 0;
}

// 修改连接回调
void on_connect(struct mosquitto *mosq, void *obj, int rc) {
    if (rc == 0) {
        printf("Connected to MQTT broker\n");
        mqtt_connected = 1;
        mqtt_reconnect_attempts = 0; // 重置重连计数
    } else {
        fprintf(stderr, "Failed to connect to MQTT broker: %s\n", mosquitto_connack_string(rc));
        mqtt_connected = 0;
    }
}

// MQTT日志回调
void on_log(struct mosquitto *mosq, void *obj, int level, const char *str) {
    printf("MQTT LOG: %s\n", str);
}

// 初始化MQTT客户端
int init_mqtt() {
    int rc;
    
    mosquitto_lib_init();
    
    mosq = mosquitto_new(NULL, true, NULL);
    if (!mosq) {
        fprintf(stderr, "Error: Out of memory.\n");
        return -1;
    }
    
    mosquitto_connect_callback_set(mosq, on_connect);
    mosquitto_disconnect_callback_set(mosq, on_disconnect);
    mosquitto_log_callback_set(mosq, on_log);
	mosquitto_message_callback_set(mosq, on_message);
    
    if (config.mqtt_username[0] != '\0') {
        mosquitto_username_pw_set(mosq, config.mqtt_username, config.mqtt_password);
    }
    
    if (config.use_tls) {
        if (config.ca_file[0] != '\0') {
            rc = mosquitto_tls_set(mosq, config.ca_file, NULL, 
                                  config.cert_file[0] != '\0' ? config.cert_file : NULL, 
                                  config.key_file[0] != '\0' ? config.key_file : NULL, 
                                  NULL);
            if (rc != MOSQ_ERR_SUCCESS) {
                fprintf(stderr, "Failed to set TLS: %s\n", mosquitto_strerror(rc));
                return -1;
            }
        }
        mosquitto_tls_opts_set(mosq, 1, NULL, NULL);
    }
    
	// 设置自动重连
    mosquitto_reconnect_delay_set(mosq, 2, 30, true); // 最短2秒，最长30秒
	
    rc = mosquitto_connect_async(mosq, config.mqtt_host, config.mqtt_port, 60);
    if (rc != MOSQ_ERR_SUCCESS) {
        fprintf(stderr, "Unable to connect to MQTT broker: %s\n", mosquitto_strerror(rc));
        // 这里不直接返回失败，让重连机制处理
    }
    
    return 0;
}

// 改进的连接检查函数
int check_and_reconnect_mqtt() {
    int rc;
    
    if (!mqtt_connected) {
        mqtt_reconnect_attempts++;
        
        if (mqtt_reconnect_attempts > MAX_RECONNECT_ATTEMPTS) {
            fprintf(stderr, "Maximum reconnect attempts reached (%d). Waiting before retry...\n", 
                   MAX_RECONNECT_ATTEMPTS);
            
            // 等待一段时间再重置计数器
            for (int i = 0; i < 10 && running; i++) { // 等待10秒
                usleep(1000000); // 1秒
                mosquitto_loop(mosq, 0, 1);
            }
            mqtt_reconnect_attempts = 0;
        }
        
        printf("Attempting to reconnect to MQTT broker (attempt %d/%d)...\n",
               mqtt_reconnect_attempts, MAX_RECONNECT_ATTEMPTS);
        
        rc = mosquitto_reconnect_async(mosq);
        if (rc != MOSQ_ERR_SUCCESS) {
            fprintf(stderr, "Reconnect failed: %s\n", mosquitto_strerror(rc));
            return 0;
        }
        
        // 等待连接建立
        for (int i = 0; i < 50 && !mqtt_connected && running; i++) { // 最多等待5秒
            usleep(100000); // 100ms
            mosquitto_loop(mosq, 0, 1);
        }
    }
    
    return mqtt_connected;
}

// 获取当前时间戳(毫秒)
long long current_timestamp() {
    struct timeval te;
    gettimeofday(&te, NULL);
    long long milliseconds = te.tv_sec * 1000LL + te.tv_usec / 1000;
    return milliseconds;
}

void on_message(struct mosquitto *mosq, void *obj, const struct mosquitto_message *msg) {
    printf("Received message on topic %s: %.*s\n", 
           msg->topic, msg->payloadlen, (char*)msg->payload);
    
    // 将数据写入串口
    if (serial_fd != -1) {
        write(serial_fd, msg->payload, msg->payloadlen);
    }
}

// 处理串口数据
void process_serial_data() {
    char buffer[SERIAL_BUFFER_SIZE];
    char packet[SERIAL_BUFFER_SIZE];
    int packet_len = 0;
    long long last_recv_time = 0;
    long long last_mqtt_check = current_timestamp();
    int n;
	
    // 数据缓冲区，用于在连接断开时暂存数据
    char data_buffer[SERIAL_BUFFER_SIZE * 10]; // 10倍缓冲区
    int data_buffer_len = 0;
    const int max_buffer_size = sizeof(data_buffer);
    
    while (running) {
        // 定期检查MQTT连接状态（每2秒）
        long long now = current_timestamp();
        if (now - last_mqtt_check > 2000) {
            last_mqtt_check = now;
            
            if (!mqtt_connected) {
                printf("MQTT connection lost, attempting to reconnect...\n");
                check_and_reconnect_mqtt();
            }
        }
        
        // 读取串口数据
        n = read(serial_fd, buffer, sizeof(buffer));
        if (n > 0) {
            // 如果有待发送的数据缓冲区且连接已恢复，先发送缓冲区数据
            if (data_buffer_len > 0 && mqtt_connected) {
                int rc = mosquitto_publish(mosq, NULL, config.mqtt_topic, 
                                          data_buffer_len, data_buffer, 0, false);
                if (rc == MOSQ_ERR_SUCCESS) {
                    printf("Published buffered data (%d bytes) to MQTT topic: %s\n", 
                           data_buffer_len, config.mqtt_topic);
                    data_buffer_len = 0;
                }
            }
            
            // 处理新接收的数据
            if (packet_len + n < SERIAL_BUFFER_SIZE) {
                memcpy(packet + packet_len, buffer, n);
                packet_len += n;
            } else {
                fprintf(stderr, "Packet buffer overflow\n");
                packet_len = 0;
            }
            last_recv_time = current_timestamp();
        } else if (n < 0 && errno != EAGAIN) {
            perror("read");
            break;
        }
        
        // 检查是否应该发送数据包（超时或缓冲区满）
        if (packet_len > 0 && 
            (current_timestamp() - last_recv_time) >= config.timeout_ms) {
            
            if (mqtt_connected) {
                int rc = mosquitto_publish(mosq, NULL, config.mqtt_topic, 
                                          packet_len, packet, 0, false);
                if (rc != MOSQ_ERR_SUCCESS) {
                    fprintf(stderr, "Failed to publish message: %s\n", mosquitto_strerror(rc));
                    mqtt_connected = 0; // 标记为断开
                    
                    // 尝试将数据存入缓冲区
                    if (data_buffer_len + packet_len < max_buffer_size) {
                        memcpy(data_buffer + data_buffer_len, packet, packet_len);
                        data_buffer_len += packet_len;
                        printf("Data buffered (%d bytes total)\n", data_buffer_len);
                    } else {
                        fprintf(stderr, "Data buffer full, discarding %d bytes\n", packet_len);
                    }
                } else {
                    printf("Published %d bytes to MQTT topic: %s\n", packet_len, config.mqtt_topic);
                }
            } else {
                // 连接断开，尝试缓冲数据
                if (data_buffer_len + packet_len < max_buffer_size) {
                    memcpy(data_buffer + data_buffer_len, packet, packet_len);
                    data_buffer_len += packet_len;
                    printf("Data buffered while disconnected (%d bytes total)\n", data_buffer_len);
                } else {
                    fprintf(stderr, "Data buffer full, discarding %d bytes\n", packet_len);
                }
            }
            
            packet_len = 0;
        }
        
        // 处理MQTT网络流量（非阻塞）
        mosquitto_loop(mosq, 0, 1);
        
        // 如果连接断开，稍微降低循环频率以减少CPU占用
        if (!mqtt_connected) {
            usleep(100000); // 100ms
        }
    }
}

// 将数字波特率转换为系统定义的波特率
int get_baudrate(int baud) {
    switch (baud) {
        case 300: return B300;
        case 600: return B600;
        case 1200: return B1200;
        case 1800: return B1800;
        case 2400: return B2400;
        case 4800: return B4800;
        case 9600: return B9600;
        case 19200: return B19200;
        case 38400: return B38400;
        case 57600: return B57600;
        case 115200: return B115200;
        case 230400: return B230400;
        case 921600: return B921600;
        default: return B115200;
    }
}

