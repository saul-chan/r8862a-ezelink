int main(int argc, char *argv[]) {
    char config_file[256] = DEFAULT_CONFIG_FILE;
    
    // 初始化默认配置
    init_default_config();
    
    // 首先尝试从默认配置文件读取配置
    read_config_file(config_file);
    
    // 解析命令行参数
    int opt;
    while ((opt = getopt(argc, argv, "d:b:h:p:u:P:c:k:t:T:m:D:S:y:o:f:")) != -1) {
        switch (opt) {
            case 'd':
                strncpy(config.serial_device, optarg, sizeof(config.serial_device));
                break;
            case 'b':
                config.baudrate = get_baudrate(atoi(optarg));
                break;
            case 'h':
                strncpy(config.mqtt_host, optarg, sizeof(config.mqtt_host));
                break;
            case 'p':
                config.mqtt_port = atoi(optarg);
                break;
            case 'u':
                strncpy(config.mqtt_username, optarg, sizeof(config.mqtt_username));
                break;
            case 'P':
                strncpy(config.mqtt_password, optarg, sizeof(config.mqtt_password));
                break;
            case 'c':
                strncpy(config.ca_file, optarg, sizeof(config.ca_file));
                break;
            case 'k':
                strncpy(config.key_file, optarg, sizeof(config.key_file));
                break;
            case 't':
                strncpy(config.cert_file, optarg, sizeof(config.cert_file));
                break;
            case 'T':
                config.use_tls = 1;
                break;
            case 'm':
                config.timeout_ms = atoi(optarg);
                if (config.timeout_ms <= 0) {
                    fprintf(stderr, "Timeout must be positive\n");
                    exit(EXIT_FAILURE);
                }
                break;
            case 'D':
                config.databits = atoi(optarg);
                if (config.databits < 5 || config.databits > 8) {
                    fprintf(stderr, "Data bits must be 5,6,7 or 8\n");
                    exit(EXIT_FAILURE);
                }
                break;
            case 'S':
                config.stopbits = atoi(optarg);
                if (config.stopbits != 1 && config.stopbits != 2) {
                    fprintf(stderr, "Stop bits must be 1 or 2\n");
                    exit(EXIT_FAILURE);
                }
                break;
            case 'y':
                config.parity = toupper(optarg[0]);
                if (config.parity != 'N' && config.parity != 'O' && config.parity != 'E') {
                    fprintf(stderr, "Parity must be N (None), O (Odd) or E (Even)\n");
                    exit(EXIT_FAILURE);
                }
                break;
            case 'o':
                strncpy(config.mqtt_topic, optarg, sizeof(config.mqtt_topic));
                break;
            case 'f':
                strncpy(config_file, optarg, sizeof(config_file));
                // 重新读取配置文件
                init_default_config();
                if (read_config_file(config_file) != 0) {
                    fprintf(stderr, "Failed to read config file: %s\n", config_file);
                    exit(EXIT_FAILURE);
                }
                break;
            default:
                print_usage(argv[0]);
                exit(EXIT_FAILURE);
        }
    }
    
    // 设置信号处理
    signal(SIGINT, handle_signal);
    signal(SIGTERM, handle_signal);
    
    // 初始化串口
    serial_fd = init_serial();
    if (serial_fd == -1) {
        fprintf(stderr, "Failed to initialize serial port\n");
        exit(EXIT_FAILURE);
    }
    
    // 初始化MQTT
    if (init_mqtt() != 0) {
        fprintf(stderr, "Failed to initialize MQTT client\n");
        close(serial_fd);
        exit(EXIT_FAILURE);
    }
	
	// 等待初始连接建立（最多10秒）
    printf("Waiting for initial MQTT connection...\n");
    for (int i = 0; i < 100 && !mqtt_connected && running; i++) { // 最多等待10秒
        usleep(100000); // 100ms
        mosquitto_loop(mosq, 0, 1);
    }
    
    if (!mqtt_connected) {
        printf("Initial MQTT connection failed, will continue trying in background...\n");
        printf("Serial data will be buffered until connection is established.\n");
    }
    
    // 打印当前配置
    print_config();
    printf("\nSerial to MQTT bridge started. Press Ctrl+C to exit.\n");
    
    // 处理串口数据
    process_serial_data();
    
    // 清理资源
    if (mosq) {
        mosquitto_disconnect(mosq);
        mosquitto_destroy(mosq);
    }
    mosquitto_lib_cleanup();
    
    if (serial_fd != -1) {
        close(serial_fd);
    }
    
    printf("Program exited cleanly\n");
    return 0;
}