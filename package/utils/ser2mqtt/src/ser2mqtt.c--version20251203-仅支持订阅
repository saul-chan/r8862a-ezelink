// 去除字符串首尾空白字符
void trim(char *str) {
    char *end;
    
    // 去除首部空白
    while(isspace((unsigned char)*str)) str++;
    
    if(*str == 0) return;
    
    // 去除尾部空白
    end = str + strlen(str) - 1;
    while(end > str && isspace((unsigned char)*end)) end--;
    
    // 写入新的结束符
    *(end+1) = 0;
}

// 从配置文件中读取配置
int read_config_file(const char *filename) {
    FILE *file = fopen(filename, "r");
    if (!file) {
        return -1; // 文件不存在不是错误，使用默认值
    }
    
    char line[MAX_LINE_LENGTH];
    char key[MAX_LINE_LENGTH];
    char value[MAX_LINE_LENGTH];
    
    while (fgets(line, sizeof(line), file)) {
        // 跳过注释和空行
        if (line[0] == '#' || line[0] == '\n') {
            continue;
        }
        
        // 分割键值对
        char *sep = strchr(line, '=');
        if (!sep) {
            continue;
        }
        
        *sep = '\0';
        strncpy(key, line, sizeof(key));
        strncpy(value, sep + 1, sizeof(value));
        
        // 去除首尾空白
        trim(key);
        trim(value);
        
        // 处理各个配置项
        if (strcmp(key, "serial_device") == 0) {
            strncpy(config.serial_device, value, sizeof(config.serial_device));
        } else if (strcmp(key, "baudrate") == 0) {
            config.baudrate = atoi(value);
			int baud = atoi(value);
			config.baudrate = get_baudrate(baud);  // 转换为B115200这样的常量
        } else if (strcmp(key, "databits") == 0) {
            config.databits = atoi(value);
        } else if (strcmp(key, "stopbits") == 0) {
            config.stopbits = atoi(value);
        } else if (strcmp(key, "parity") == 0) {
            config.parity = toupper(value[0]);
        } else if (strcmp(key, "timeout_ms") == 0) {
            config.timeout_ms = atoi(value);
        } else if (strcmp(key, "mqtt_host") == 0) {
            strncpy(config.mqtt_host, value, sizeof(config.mqtt_host));
        } else if (strcmp(key, "mqtt_port") == 0) {
            config.mqtt_port = atoi(value);
        } else if (strcmp(key, "mqtt_username") == 0) {
            strncpy(config.mqtt_username, value, sizeof(config.mqtt_username));
        } else if (strcmp(key, "mqtt_password") == 0) {
            strncpy(config.mqtt_password, value, sizeof(config.mqtt_password));
        } else if (strcmp(key, "ca_file") == 0) {
            strncpy(config.ca_file, value, sizeof(config.ca_file));
        } else if (strcmp(key, "cert_file") == 0) {
            strncpy(config.cert_file, value, sizeof(config.cert_file));
        } else if (strcmp(key, "key_file") == 0) {
            strncpy(config.key_file, value, sizeof(config.key_file));
        } else if (strcmp(key, "use_tls") == 0) {
            config.use_tls = atoi(value);
        } else if (strcmp(key, "mqtt_topic") == 0) {
            strncpy(config.mqtt_topic, value, sizeof(config.mqtt_topic));
        }
    }
    
    fclose(file);
    return 0;
}

