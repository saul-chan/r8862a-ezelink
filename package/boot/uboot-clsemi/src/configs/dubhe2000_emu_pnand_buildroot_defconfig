CONFIG_FIT=y
CONFIG_GZIP=y
CONFIG_CMD_MEMTEST=y
CONFIG_SYS_ALT_MEMTEST=y
CONFIG_CLOURNEY_SEMI=y
CONFIG_BRD_BOOT_FLASH_VARIANT=1
CONFIG_BRD_PLAT_RUN_CLK_VARIANT=1
