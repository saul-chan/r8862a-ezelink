CONFIG_ARM=y
CONFIG_TARGET_DUBHE2000_EMU=y
CONFIG_SYS_TEXT_BASE=0x00080000
CONFIG_SYS_MALLOC_LEN=0x120000
CONFIG_NR_DRAM_BANKS=1
CONFIG_ENV_OFFSET=0x180000
CONFIG_ENV_SIZE=0x20000
CONFIG_ENV_IS_IN_NAND=y
CONFIG_NAND_BOOT=y
CONFIG_SYS_LOAD_ADDR=0x00200000
CONFIG_DEFAULT_DEVICE_TREE="clourneysemi-dubhe2000-emu-pnand"
CONFIG_BOOTDELAY=1
CONFIG_OF_CONTROL=y
CONFIG_OF_EMBED=y
CONFIG_DM=y
CONFIG_DM_SERIAL=y
