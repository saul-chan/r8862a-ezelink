msgid "By filtering IP addresses and MAC addresses, black and white lists can help manage the network connection status of access devices."
msgstr "Фильтруя IP-адреса и MAC-адреса, чёрный и белый списки помогают управлять сетевым подключением устройств доступа."

msgid "White List:Only allow devices in the following list to connect to the Internet.</br>"
msgstr "Белый список: разрешить доступ в Интернет только устройствам из следующего списка.</br>"

msgid "Black List:Devices in the following list are prohibited from connecting to the Internet."
msgstr "Чёрный список: устройствам из следующего списка запрещено подключаться к Интернету."

msgid "All"
msgstr "Все"

msgid "Completely forward the communication sent to a port of the external network to a designated port of an address of the internal network."
msgstr "Полностью пересылает связь, отправленную на порт внешней сети, на указанный порт адреса во внутренней сети."

msgid "External IP address"
msgstr "Внешний IP-адрес"

msgid "Internal IP address"
msgstr "Внутренний IP-адрес"

msgid "The specified address performs a one-to-one mapping"
msgstr "Указанный адрес выполняет взаимно-однозначное отображение"

msgid "1:1 NAT Records"
msgstr "Записи 1:1 NAT"

