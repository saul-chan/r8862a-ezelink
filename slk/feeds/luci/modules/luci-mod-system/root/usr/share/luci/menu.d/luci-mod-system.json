			"type": "view",
			"path": "system/mounts"
		},
		"depends": {
			"acl": [ "luci-mod-system-mounts" ],
			"fs": { "/sbin/block": "executable" }
		}
	},

	"admin/system/flash": {
		/*"title": "Backup / Flash Firmware",*/
