config SND_DESIGNWARE_I2S
	tristate "Synopsys I2S Device Driver"
	depends on CLKDEV_LOOKUP
	select SND_SOC_GENERIC_DMAENGINE_PCM
	help
	 Say Y or M if you want to add support for I2S driver for
	 Synopsys designware I2S device. The device supports up to
	 a maximum of 8 channels each for play and record.

config SND_DESIGNWARE_TDM
        bool "TDM extension for I2S driver"
        depends on SND_DESIGNWARE_I2S
        help
         Say Y or N if you want to add a custom ALSA extension that registers
         a TDM and uses PIO or interal DMA to transfer data.

         This functionality is specially suited for I2S devices that don't have
         External DMA support.

config SND_DESIGNWARE_PCM
	bool "PCM PIO extension for I2S driver"
	depends on SND_DESIGNWARE_I2S
	help
	 Say Y or N if you want to add a custom ALSA extension that registers
	 a PCM and uses PIO to transfer data.

	 This functionality is specially suited for I2S devices that don't have
	 DMA support.

config I2S_DMA_REPLACE_FIFO
	bool "I2S DMA is enabled, replace LTHRx and RTHRx"
	depends on SND_DESIGNWARE_I2S
	help
	 Say Y or N when data to be transmitted/receivered by TX/RX
	 channels are written/readed to the TX/RX FIFOs through the
	 TXDMA/RXDMA register rather than through LTHRx and RTHRx.

config TDM_DMA_REPLACE_FIFO
        bool "TDM DMA is enabled, replace TSLOTx and RSLOTx"
        depends on SND_DESIGNWARE_I2S
        help
	 Say Y or N when data to be transmitted/receivered by TX/RX
	 channels are written/readed to the TX/RX FIFOs through the
	 TXDMA/RXDMA register rather than through TSLOTx and RSLOTx.
