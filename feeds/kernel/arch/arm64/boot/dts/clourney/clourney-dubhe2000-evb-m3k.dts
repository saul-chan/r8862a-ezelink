/dts-v1/;
#include "clourney-dubhe2000.dtsi"

/ {
	model = "Clourney Semiconductor D2K + M3K EVB Board";
	compatible = "clsemi,dubhe2000-evb-m3k", "clsemi,dubhe2000";

	aliases {
		serial0 = &duart0;
		spidev0 = &spi0;
                spidev1 = &spi1;
		spidev2 = &spi2;
		spinand = &spiflash;

	};

	chosen {
		stdout-path = "serial0:115200n8";
	};

	macros {
	    #define MMC_CARD_USED   1
	 };
};

&duart0 {
	status = "ok";
};

&spi0 {
	status = "ok";
	spidev@0 {
		spi-max-frequency = <5000000>;
		reg = <0>;
		compatible = "linux,spidev";
	};
};

&spi1 {
	status = "ok";
	spidev@0 {
		spi-max-frequency = <5000000>;
		reg = <0>;
		compatible = "linux,spidev";
	};
};

&spi2 {
	status = "ok";
	spidev@0 {
		spi-max-frequency = <5000000>;
		reg = <0>;
		compatible = "linux,spidev";
	};
};

&i2c0 {
        label = "I2C0";
        status = "okay";
};

&i2c1 {
	label = "I2C1";
	status = "okay";
};

&i2c2 {
        label = "I2C2";
        status = "okay";
};

&spiflash {
	rx-sample-delay-ns = <8>;
	status = "ok";

	nand_flash: flash@0 {
		compatible = "spi-nand";
		/* Avoid interference with 5G and 2.4G, not setting clk to  41.67MHz  */
		spi-max-frequency = <31250000>;
		reg = <0>;
		#address-cells = <1>;
		#size-cells = <1>;

		/*0.5MB*/
		partition@0 {
			label = "sbl";
			reg = <0x0 0x80000>;
		};

		/*0.5MB*/
		partition@1 {
			label = "atf";
			reg = <0x80000 0x80000>;
		};

		/*1MB*/
		partition@2 {
			label = "platformdata";
			reg = <0x100000 0x100000>;
		};

		/*2MB*/
		partition@3 {
			label = "uboot";
			reg = <0x200000 0x200000>;
		};

		/*1MB*/
		partition@4 {
			label = "caldata";
			reg = <0x400000 0x100000>;
		};

		/*1MB*/
		partition@5 {
			label = "caldata2";
			reg = <0x500000 0x100000>;
		};

		/*1.5MB*/
                partition@6 {
                        label = "ubootenv";
                        reg = <0x600000 0x180000>;
                };

		/*1.5MB*/
                partition@7 {
                        label = "boarddata";
                        reg = <0x780000 0x180000>;
                };

		/*32MB*/
                partition@8 {
                        label = "fw1";
                        reg = <0x900000 0x2000000>;
                };

		/*32MB*/
                partition@9 {
                        label = "fw2";
                        reg = <0x2900000 0x2000000>;
                };

		/*55MB*/
                partition@10 {
                        label = "reserved";
                        reg = <0x4900000 0x3700000>;
                };
	};
};

&npe  {
	status = "ok";
	switch-pause = <4>;
};

&xpcs0 {
	phy-mode = "usxgmii";
	usxg_mode = <0>;
	status = "okay";
};

&xpcs1 {
	phy-mode = "sgmii";
	status = "okay";
};

&xgmac0 {
	mode = "non-rgmii";
	max-speed = <10000>;
	mac-address = [a0 c0 ab 39 cc f0];
	sfp;
	mdio-flags = <1>;
	clk_csr = <1>;
	status = "okay";
	mdio {
	compatible = "clourney,mdio";
	#address-cells = <1>;
	#size-cells = <0>;
	device_type = "mdio";
	status = "okay";
	rgmii1_phy: ethernet-phy@5 {
		 compatible = "realtek,8211f","ethernet-phy-ieee802.3-c22";
		 reg = <0x5>;
	};
	qsgmii_phy0: ethernet-phy@8 {
		 compatible = "ethernet-phy-ieee802.3-c22";
		 port-id = <0>;
		 reg = <0x8>;
	};
	qsgmii_phy1: ethernet-phy@9 {
		compatible = "ethernet-phy-ieee802.3-c22";
		port-id = <1>;
		reg = <0x9>;
	};
	qsgmii_phy2: ethernet-phy@a {
		compatible = "ethernet-phy-ieee802.3-c22";
		port-id = <2>;
		reg = <0xa>;
	};
	qsgmii_phy3: ethernet-phy@b {
		compatible = "ethernet-phy-ieee802.3-c22";
		port-id = <3>;
		reg = <0xb>;
	};
	sgmii0_phy: ethernet-phy@01 {
		compatible = "ethernet-phy-ieee802.3-c22";
		reg = <0x2>;
	};
	sgmii1_phy: ethernet-phy@1 {
		compatible = "ethernet-phy-ieee802.3-c22";
		reg = <0x1>;
	};
	rgmii0_phy: ethernet-phy@3 {
		compatible = "ethernet-phy-ieee802.3-c22";
		reg = <0x3>;
	};
	rgmii2_phy: ethernet-phy@7 {
		compatible = "ethernet-phy-ieee802.3-c22";
		reg = <0x7>;
	};
  };
};

&xgmac4 {
	mode = "rgmii";
	max-speed = <1000>;
	mac-address = [a0 c0 ab 39 cc f2];
	mdio-flags = <1>;
	phy-handle = <&rgmii1_phy>;
	rgmii-rx-delay = <1>;
	mdio-flags = <1>;
	status = "okay";
};


&xgmac1 {
	mode = "non-rgmii";
	mac-address = [a0 c0 ab 39 cc f3];
	max-speed = <25000>;
	phy-handle = <&sgmii1_phy>;
	mdio-flags = <1>;
	status = "okay";
};

&xgmac2 {
	status = "disabled";
};

&xgmac3 {
	status = "disabled";
};

&wifi0 { status = "disabled"; };

&wifi1 { status = "disabled"; };

&wifiarc { status = "disabled"; };

&crgwdt {
        timeout-sec = <WDT_TIMEOUT_S>;
        status = "ok";
};

&watchdog0 {
	timeout-sec = <WDT_TIMEOUT_S>;
	status = "ok";
};

&gpio0 { status = "ok"; };

&gpio1 { status = "ok"; };

&gpio_keys { status = "ok"; };

&gpio_leds { status = "ok"; };

&usbdrd3 { status = "ok";};

&usb {status = "ok"; };

&sdhci {
	disable-wp;
	keep-power-in-suspend;
	sdhci-caps-mask = <0xff0000 0x0>;
	sdhci-caps = <0x0 0x0>;
	max-frequency = <125000000>;

	#if MMC_CARD_USED
	bus-width = <8>;
	non-removable;
	no-sdio;
	no-sd;
	cap-mmc-highspeed;
	mmc-hs200-1_8v;
	keep-power-in-suspend;
	/* HS400 mode */
	#elif SD_CARD_USED
	bus-width = <4>;
	no-sdio;
	no-mmc;
	supports-sd;
	card-detect-delay = <2000>;
	cap-sd-highspeed;
	/* controller clock frequence low than 50M is recommended */
	sd-uhs-sdr12;
	sd-uhs-sdr25;
	sd-uhs-sdr50;
	sd-uhs-sdr104;
	no-1-8-v;
	#elif SDIO_CARD_USED
	no-sd;
	no-mmc;
	#endif
	status = "disabled";
};

&pvt_sensor {
	status = "disabled";
        // T2
        temp_rise_alarm2_L = "102000";
        temp_rise_alarm2_H = "110000";
        temp_fall_alarm2_H = "110000";
        temp_fall_alarm2_L = "102000";
        // T0
        temp_rise_alarm0_L = "110000";
        temp_rise_alarm0_H = "118000";
        temp_fall_alarm0_H = "118000";
        temp_fall_alarm0_L = "110000";
        // T1
        temp_rise_alarm1_L = "118000";
        temp_rise_alarm1_H = "126000";
        temp_fall_alarm1_H = "126000";
        temp_fall_alarm1_L = "118000";
};

&cls_tsens {
	status = "ok";
        // T2
        temp_rise_alarm2_L = "102000";
        temp_rise_alarm2_H = "110000";
        temp_fall_alarm2_H = "110000";
        temp_fall_alarm2_L = "102000";
        // T0
        temp_rise_alarm0_L = "110000";
        temp_rise_alarm0_H = "118000";
        temp_fall_alarm0_H = "118000";
        temp_fall_alarm0_L = "110000";
        // T1
        temp_rise_alarm1_L = "118000";
        temp_rise_alarm1_H = "126000";
        temp_fall_alarm1_H = "126000";
        temp_fall_alarm1_L = "118000";
};

&clspcierc {
	perst-gpio = <&gpio0 10 1>;
	status = "ok";
};
