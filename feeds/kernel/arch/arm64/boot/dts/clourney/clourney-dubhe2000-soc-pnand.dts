/dts-v1/;
#include "clourney-dubhe2000.dtsi"

/ {
	model = "DUBHE2000 SOC Board";
	compatible = "clourney,dubhe2000";

	aliases {
		serial0 = &duart0;
		spidev0 = &spi0;
	};

	chosen {
		stdout-path = "serial0:9600n8";
	};
};

&duart0 {
	status = "ok";
};

&spi0 {
	status = "ok";
	spidev@0 {
		spi-max-frequency = <4000000>;
		reg = <0>;
		compatible = "linux,spidev";
	};
};

&nandctrl {
	status = "ok";

	flash@0 {
		linux,mtd-name= "micron,mt29f1g08abb";
		#address-cells = <1>;
		#size-cells = <1>;
		reg = <0>;

		partition@0 {
			label = "nandflash-sbl";
			reg = <0x0 0x20000>;
		};

		partition@0x20000 {
			label = "nandflash-atf";
			reg = <0x20000 0x60000>;
		};

		partition@0x80000 {
			label = "nandflash-uboot";
			reg = <0x80000 0x80000>;
		};

		partition@0x100000 {
			label = "nandflash-dtb";
			reg = <0x100000 0x100000>;
		};

		partition@0x200000 {
			label = "nandflash-kernel";
			reg = <0x200000 0x1e00000>;
		};

		partition@0x2000000 {
			label = "nandflash-rootfs";
			reg = <0x2000000 0x6000000>;
		};
	};
};

&npe  { status = "ok"; };

&wifi0 { status = "ok"; };

&wifi1 { status = "ok"; };

&watchdog0 {
	timeout-sec = <WDT_TIMEOUT_S>;
	status = "ok";
};

&gpio0 { status = "ok"; };

&gpio1 { status = "ok"; };

&gpio_keys { status = "ok"; };

&gpio_leds { status = "ok"; };
